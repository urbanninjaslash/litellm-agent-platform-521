# Postgres — default points at the local container in docker-compose.yml.
DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm_agents

# UI auth — user signs in at /login with MASTER_KEY; UI_USERNAME is display only.
UI_USERNAME=admin
MASTER_KEY=

# Kubernetes sandbox runtime.
#   K8S_NAMESPACE         namespace Sandbox CRs and Services live in
#   K8S_NODE_HOST         host the web container reaches the k8s node on.
#                         docker-compose: host.docker.internal (default).
#                         next dev on host: 127.0.0.1.
#   K8S_NODEPORT_MIN/MAX  NodePort range exposed on the host (kind: matches
#                         extraPortMappings — see bin/kind-up.sh).
#   K8S_IMAGE_PULL_POLICY Never for kind-loaded local images, IfNotPresent
#                         or Always for registry-backed images.
#   K8S_HARNESS_IMAGE     container image for the opencode harness pod.
#   K8S_API_SERVER        override kubeconfig cluster URL in-process. Use
#                         when the kubeconfig server is unreachable from the
#                         running process (e.g. compose container can't dial
#                         127.0.0.1). Skips TLS verify — local kind only.
K8S_NAMESPACE=default
K8S_NODE_HOST=host.docker.internal
K8S_NODEPORT_MIN=30000
K8S_NODEPORT_MAX=30099
K8S_IMAGE_PULL_POLICY=Never
K8S_HARNESS_IMAGE=opencode-sandbox:dev
K8S_API_SERVER=

# Repo cloned into sandbox at session start (used when agent.repo_url is null).
PREINSTALLED_GITHUB_REPO=https://github.com/BerriAI/litellm

# LiteLLM model + MCP gateway — also used by the UI to list MCP servers from
# /v1/mcp/server and per-server tools from /mcp-rest/tools/list.
LITELLM_API_BASE=https://your-litellm-proxy.example.com
LITELLM_API_KEY=sk-...

# Tuning.
CONTAINER_PORT=4096
RECONCILE_INTERVAL_SECONDS=60

# Warm pool — pre-provisioned sandbox pods waiting to be claimed by a
# session create. Default of 2 keeps two pods ready for the most recently
# active agent so users get sub-2s session creates out of the box. Set
# WARM_POOL_SIZE=0 to disable.
#   WARM_POOL_SIZE                target across all agents
#   WARM_POOL_MAX_PROVISIONING    concurrency cap on the top-up loop
#   WARM_POOL_TTL_MINUTES         recycle warm pods older than this
#   WARM_POOL_RECENT_AGENT_HOURS  ignore agents not used in the last N hours
WARM_POOL_SIZE=2
WARM_POOL_MAX_PROVISIONING=2
WARM_POOL_TTL_MINUTES=30
WARM_POOL_RECENT_AGENT_HOURS=24

# Anything matching CONTAINER_ENV_* is injected into every sandbox container
# with the prefix stripped. Example:
#   CONTAINER_ENV_GITHUB_TOKEN=ghp_...  →  container sees GITHUB_TOKEN=ghp_...

# =============================================================================
# Integrations subsystem (src/server/integrations/)
# =============================================================================
# Public URL of this LAP deployment. Used to build OAuth `redirect_uri` and
# the in-process URL the dispatcher hits when spawning a Session via the v1
# route. Defaults to http://localhost:3000 in dev.
BASE_URL=

# Token-encryption key for IntegrationInstall.access_token / refresh_token.
# Base64-encoded 32 bytes. REQUIRED in production; if unset, tokens are
# stored as plaintext and a warning is logged (dev only).
#   Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── Linear ───────────────────────────────────────────────────────────────────
# Create an OAuth app at https://linear.app/settings/api/applications/new.
# Redirect URL: ${BASE_URL}/api/integrations/oauth/linear/callback
# Webhook URL:  ${BASE_URL}/api/integrations/webhooks/linear
# Enable the "Agent session events" webhook category.
# Required scopes (auto-requested by the integration): read, write,
# app:assignable, app:mentionable.
# Leaving any of these blank disables the Linear integration — its routes
# return 404 instead of registering.
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot OAuth token from your Slack app (api.slack.com/apps → OAuth & Permissions
# → Bot User OAuth Token). The bot needs the `chat:write` scope at minimum.
# Injected into every sandbox container as SLACK_BOT_TOKEN, enabling the
# `mcp__lap-slack__post_slack_message` managed tool in the claude-agent-sdk
# harness. Leaving this blank disables the Slack tool — agents boot cleanly
# without it.
CONTAINER_ENV_SLACK_BOT_TOKEN=
